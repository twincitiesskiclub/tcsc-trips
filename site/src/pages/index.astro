---
// Home: full composition from primitives (Phase K, Task 30).
// Hero + mission come from the `home` singleton; CTA labels/urls resolve
// through getRegistrationCta (single source for every CTA consumer).
// LiveConditions mounts ONCE, prominent; the inner pages get the compact
// variant via InnerPageLayout (the announcer assumes one mount per page).
import { getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import MobileNavPanel from '@/components/MobileNavPanel.astro';
import CtaForState from '@/components/CtaForState.astro';
import LiveConditions from '@/components/LiveConditions.astro';
import HeroHome from '@/components/HeroHome.astro';
import MissionPanel from '@/components/MissionPanel.astro';
import SectionBand from '@/components/SectionBand.astro';
import SeasonsGrid from '@/components/SeasonsGrid.astro';
import PhotoMosaic from '@/components/PhotoMosaic.astro';
import WaxRoomFeed from '@/components/WaxRoomFeed.astro';
import SponsorWall from '@/components/SponsorWall.astro';
import CTAStrip from '@/components/CTAStrip.astro';
import Footer from '@/components/Footer.astro';
import { getRegistrationCta } from '@/components/registrationCta';
import { metaDescription } from '@/lib/metaDescription';

const home = await getEntry('home', 'home');
if (!home) throw new Error('home singleton missing (src/content/pages/home.yaml)');
const h = home.data;
const meta = await getEntry('site_meta', 'site_meta');
const cta = await getRegistrationCta();
const description = meta?.data.description
  ? metaDescription(meta.data.description)
  : undefined;

// CTA strip label + target follow registration state together. Never '#':
// with no url at all, point at registration on tcsc.ski so the button
// always goes somewhere real. The public site never links the club Slack.
const ctaStripUrl =
  (cta.state === 'open'
    ? cta.url_open
    : cta.state === 'coming_soon'
      ? (cta.url_coming_soon ?? cta.url_closed)
      : cta.url_closed) ?? 'https://tcsc.ski/';
const ctaStripLabel =
  cta.state === 'open'
    ? cta.label_open
    : cta.state === 'coming_soon'
      ? cta.label_coming_soon
      : cta.label_closed;
const ctaStripSubhead =
  cta.state === 'open'
    ? 'Intermediate ability and up. No racing required.'
    : cta.state === 'coming_soon'
      ? 'Returning members Aug 28; new members Sep 3. Intermediate ability and up, no racing required.'
      : 'Registration is closed. Intermediate ability and up, no racing required.';
---
<BaseLayout
  title={meta?.data.title ?? 'Twin Cities Ski Club'}
  variant="home"
  description={description}
  ogImage={meta?.data.og_image}
>
  <Nav />
  <MobileNavPanel>
    <CtaForState slot="cta" {...cta} />
  </MobileNavPanel>
  <LiveConditions variant="prominent" />
  <main id="main">
  <HeroHome
    headline={h.hero_headline}
    subline="Year-round cross-country ski training for adults 21-35."
    image={h.hero_image}
    imageAlt={h.hero_image_alt}
    state={h.registration_state}
    cta_open_label={cta.label_open} cta_open_url={cta.url_open}
    cta_coming_soon_label={cta.label_coming_soon} cta_coming_soon_url={cta.url_coming_soon}
    cta_closed_label={cta.label_closed} cta_closed_url={cta.url_closed}
  />
  {h.mission_paragraph && <MissionPanel body={h.mission_paragraph} />}
  <SectionBand variant="navy" seam="Seasons">
    <SeasonsGrid variant="navy" headingLevel="h2" />
  </SectionBand>
  <PhotoMosaic
    homeOnly={true}
    number={null}
    heading="Beyond practice"
    more_href="/community"
    more_label="See what members do"
  />
  <WaxRoomFeed />
  <SectionBand variant="paper" seam="Our sponsors">
    <div class="flex flex-wrap items-center justify-between gap-x-12 gap-y-8">
      <SponsorWall variant="strip" />
      <a
        href="/sponsors"
        class="text-sm font-semibold text-navy underline underline-offset-4 decoration-ink/30 hover:decoration-mint-deep hover:text-mint-deep transition-colors"
      >About our sponsors</a>
    </div>
  </SectionBand>
  <CTAStrip
    id="registration"
    heading="Come ski with us."
    subhead={ctaStripSubhead}
    cta_label={ctaStripLabel}
    cta_url={ctaStripUrl}
  />
  </main>
  <Footer />
</BaseLayout>
