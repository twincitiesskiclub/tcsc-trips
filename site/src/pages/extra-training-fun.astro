---
// /extra-training-fun: the member-organized, uncoached training culture,
// named for the club Slack channel it lives in. Prose explains the system;
// the navy band lists current standing fixtures; the paper band lists the
// annual traditions; two consented pool photos sit between them.
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import InnerPageLayout from '@/layouts/InnerPageLayout.astro';
import SectionBand from '@/components/SectionBand.astro';
import { MOSAIC } from '@/components/imageWidths';
import { metaDescription } from '@/lib/metaDescription';

const page = await getEntry('extra_training', 'extra_training');
if (!page) throw new Error('extra_training singleton missing (src/content/pages/extra_training.mdoc)');
const { Content } = await render(page);
const d = page.data;
const photos = [
  { src: d.photo_1, alt: d.photo_1_alt, caption: d.photo_1_caption },
  { src: d.photo_2, alt: d.photo_2_alt, caption: d.photo_2_caption },
].filter((p) => p.src);
---
<InnerPageLayout
  title="Extra Training Fun · Twin Cities Ski Club"
  description={d.intro && metaDescription(d.intro)}
  headline={d.headline ?? 'Extra training fun'}
  subhead={d.intro}
  facts={[{ value: '2022', label: 'Member-led since' }]}
>
  <div class="safe-inline-6 mx-auto max-w-3xl px-6 py-12">
    <div class="prose prose-lg max-w-prose text-ink">
      <Content />
    </div>
  </div>
  {d.fixtures.length > 0 && (
    <SectionBand variant="navy" seam="Standing invitations">
      <div class="divide-y divide-mint/15 border-t border-mint/15">
        {d.fixtures.map((f) => (
          <div class="py-6 grid gap-x-8 gap-y-1 md:grid-cols-[16rem_1fr]">
            <div>
              <div class="font-semibold text-paper">{f.name}</div>
              {f.when && <div class="mt-1 text-sm text-mint/90">{f.when}</div>}
            </div>
            {f.what && <p class="text-paper/80 max-w-prose">{f.what}</p>}
          </div>
        ))}
      </div>
    </SectionBand>
  )}
  {photos.length > 0 && (
    <section class="safe-inline-6-10 mx-auto max-w-7xl px-6 md:px-10 py-14 md:py-20" aria-label="Photos">
      <div class="grid gap-6 md:grid-cols-2">
        {photos.map((p) => (
          <figure>
            <div class="relative aspect-[4/3] overflow-hidden">
              <Image
                src={p.src!}
                alt={p.alt ?? ''}
                widths={MOSAIC}
                width={Math.min(1600, p.src!.width)}
                height={Math.round((Math.min(1600, p.src!.width) * 3) / 4)}
                fit="cover"
                position="attention"
                sizes="(min-width: 768px) 50vw, 100vw"
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
            {p.caption && <figcaption class="mt-2 text-sm text-slate">{p.caption}</figcaption>}
          </figure>
        ))}
      </div>
    </section>
  )}
  {d.annuals.length > 0 && (
    <SectionBand variant="paper" seam="The annuals">
      <div class="divide-y divide-ink/10 border-t border-ink/10">
        {d.annuals.map((a) => (
          <div class="py-6 grid gap-x-8 gap-y-1 md:grid-cols-[16rem_1fr]">
            <div class="font-semibold text-navy">{a.name}</div>
            {a.detail && <p class="text-ink/80 max-w-prose">{a.detail}</p>}
          </div>
        ))}
      </div>
      <p class="mt-10 text-ink/80">
        The club also puts on its own fall race:{' '}
        <a
          href="/dry-tri"
          class="font-semibold text-navy underline underline-offset-4 decoration-ink/30 hover:decoration-mint-deep hover:text-mint-deep transition-colors"
        >the TCSC Dry Tri</a>.
      </p>
    </SectionBand>
  )}
</InnerPageLayout>
