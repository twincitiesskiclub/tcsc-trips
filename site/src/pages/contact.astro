---
// /contact: email, mailing address, and (when set) Instagram, from the
// `contact` singleton. Every field is optional in the schema, so each
// line renders conditionally.
import { getEntry } from 'astro:content';
import InnerPageLayout from '@/layouts/InnerPageLayout.astro';

const contact = await getEntry('contact', 'contact');
if (!contact) throw new Error('contact singleton missing (src/content/pages/contact.yaml)');
const { email, mailing_address, instagram_url } = contact.data;
---
<InnerPageLayout
  title="Contact · Twin Cities Ski Club"
  description="contact@twincitiesskiclub.org · Minneapolis - St. Paul, Minnesota"
  headline="Contact"
>
  <div class="mx-auto max-w-3xl px-6 py-12">
    <div class="prose prose-lg max-w-prose text-ink">
      {email && (
        <p>
          Email us at <a href={'mailto:' + email}>{email}</a>
        </p>
      )}
      {mailing_address && <p>{mailing_address}</p>}
      {instagram_url && (
        <p>
          Follow along on <a href={instagram_url}>Instagram</a>
        </p>
      )}
    </div>
  </div>
</InnerPageLayout>
