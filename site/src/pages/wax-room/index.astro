---
// /wax-room: index of all Wax Room entries, newest first.
// entry.id = filename slug (url), entry.data.slug = display title.
import { getCollection } from 'astro:content';
import InnerPageLayout from '@/layouts/InnerPageLayout.astro';
import { longDate } from '@/lib/formatDate';

const entries = (await getCollection('wax_entries')).sort(
  (a, b) => +b.data.date - +a.data.date || a.id.localeCompare(b.id),
);
---
<InnerPageLayout
  title="The Wax Room · Twin Cities Ski Club"
  description="Conditions reports, wax notes, race prep, and technique from TCSC coaches and members."
  headline="The Wax Room"
  subhead="Conditions, wax notes, race-day prep, technique. Field reports from TCSC coaches and members."
>
  <div class="mx-auto max-w-3xl px-6 py-12 md:py-16">
    {entries.length === 0 ? (
      <p class="text-slate">No entries yet.</p>
    ) : (
      <div class="divide-y divide-ink/10">
        {entries.map((e) => (
          <article class="py-10 first:pt-0 last:pb-0">
            <div class="text-sm text-slate">
              {longDate(e.data.date)}
            </div>
            <h2 class="font-display font-semibold text-2xl md:text-3xl text-navy mt-2 leading-tight">
              <a href={'/wax-room/' + e.id} class="hover:text-mint-deep transition-colors">
                {e.data.slug}
              </a>
            </h2>
            {e.data.author_name && (
              <div class="mt-2 text-slate text-sm">
                By {e.data.author_name} · <span class="capitalize">{e.data.author_role}</span>
              </div>
            )}
            {e.data.lede && <p class="mt-3 text-ink/90 leading-relaxed">{e.data.lede}</p>}
          </article>
        ))}
      </div>
    )}
  </div>
</InnerPageLayout>
