---
interface Props {
  variant?: 'navy' | 'paper' | 'paper-on-navy';
  /** @deprecated numbered eyebrow markers; use `seam` instead. */
  number?: string;
  /** Catalog-divider seam: a full-bleed hairline at the section's top edge,
      interrupted at the left gutter by the section name sitting ON the line.
      Physical chapter breaks instead of padding gaps wearing badges. */
  seam?: string;
  heading?: string;
  subhead?: string;
  contentMax?: 'wide' | 'narrow';
}
const { variant = 'paper', number, seam, heading, subhead, contentMax = 'wide' } = Astro.props;

// paper-on-navy: navy band with a rounded paper card inside; the px-6 gutter
// keeps the card off the viewport edges below the max width.
const isCard = variant === 'paper-on-navy';
const surface = variant === 'navy' ? 'bg-navy text-paper' : isCard ? 'bg-navy py-20' : 'bg-paper text-ink';
const innerMax = contentMax === 'narrow' ? 'max-w-3xl' : 'max-w-7xl';
const padding = isCard
  ? 'rounded-xl px-8 py-12 md:px-16 md:py-20'
  : 'px-6 md:px-10 pb-20 md:pb-28 ' + (seam ? 'pt-10 md:pt-14' : 'pt-20 md:pt-28');
// The seam label's swatch must match the section surface exactly so it reads
// as cutting the line, not floating over it.
const seamRule = variant === 'navy' ? 'border-mint/20' : 'border-ink/15';
const seamSwatch = variant === 'navy' ? 'bg-navy text-mint' : 'bg-paper text-mint-deep';
---
<section class:list={[surface, seam && !isCard && 'border-t ' + seamRule]}>
  {seam && !isCard && (
    <div class={'mx-auto ' + innerMax + ' px-6 md:px-10'}>
      <span class={'inline-block -translate-y-1/2 pr-4 text-sm tracking-wide ' + seamSwatch}>{seam}</span>
    </div>
  )}
  <div class={isCard ? 'px-6' : undefined}>
    <div class={'mx-auto ' + innerMax + ' ' + (isCard ? 'bg-paper text-ink ' : '') + padding}>
      {number && (
        <div class={'text-sm font-semibold tracking-wider mb-3 ' + (variant === 'navy' ? 'text-mint' : 'text-mint-deep')}>{number}</div>
      )}
      {heading && (
        <h2 class="font-display text-4xl md:text-5xl leading-[1.05] mb-4">{heading}</h2>
      )}
      {subhead && (
        <p class="text-lg leading-relaxed max-w-prose mb-8 opacity-90">{subhead}</p>
      )}
      <slot />
    </div>
  </div>
</section>
