---
// WaxRoomFeed: home-page strip of the three newest Wax Room entries.
// Renders nothing when the collection is empty (pre-season state).
//
// entry.id = filename slug (url), entry.data.slug = display title
// (see content.config.ts header).
//
// CONTRAST: the "All entries" link uses text-mint/80 on bg-navy; mint-deep
// on navy fails AA (same finding as the SectionBand review).
import { getCollection } from 'astro:content';
import { shortDate } from '@/lib/formatDate';

const entries = (await getCollection('wax_entries'))
  .sort((a, b) => +b.data.date - +a.data.date || a.id.localeCompare(b.id))
  .slice(0, 3);
---
{entries.length > 0 && (
  <section class="bg-navy py-20">
    <div class="mx-auto max-w-7xl px-6">
      <div class="flex items-end justify-between mb-8">
        <div>
          <div class="text-sm font-semibold tracking-wider mb-3 text-mint">03 · Wax Room</div>
          <h2 class="font-display text-3xl md:text-4xl text-paper leading-[1.05]">From the Wax Room</h2>
        </div>
        <a href="/wax-room" class="shrink-0 text-mint/80 text-sm hover:text-mint">All entries</a>
      </div>
      {/* Logbook grammar, not tiles: each entry is a dated field-log line
          (date · author / title / one line of trail truth). The form is the
          design; every future club-written entry inherits the voice. */}
      <ul class="border-y border-mint/15 divide-y divide-mint/15">
        {entries.map((e) => (
          <li>
            <a
              href={'/wax-room/' + e.id}
              class="group grid items-baseline gap-x-6 gap-y-1 py-4 md:grid-cols-[8.5rem_1fr_auto]"
            >
              <span class="text-xs text-coral tabular-nums">
                {shortDate(e.data.date)}{e.data.author_name ? ` · ${e.data.author_name}` : ''}
              </span>
              <span class="font-display text-lg text-mint leading-tight transition-colors duration-150 group-hover:text-paper">
                {e.data.slug}
                {e.data.lede && (
                  <span class="ml-3 font-sans text-sm font-normal text-paper/70">{e.data.lede}</span>
                )}
              </span>
              {e.data.conditions_snapshot?.temp_f != null && (
                <span class="text-xs text-paper/55 tabular-nums">
                  {e.data.conditions_snapshot.temp_f}°F
                  {e.data.conditions_snapshot.location ? ` · ${e.data.conditions_snapshot.location}` : ''}
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}
