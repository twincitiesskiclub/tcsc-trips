---
// WaxRoomFeed: home-page strip of the three newest Wax Room entries, set as
// a full-bleed PAPER band: with the mission panel it gives the home scroll
// its navy/paper rhythm (the spine fix from the UI debate; the teaser also
// shares a surface with its paper destination page, so the rhythm is
// truthful). Logbook grammar, not tiles: each entry is a dated field-log
// line (date · author / title / one line of trail truth); the form is the
// design, so every future club-written entry inherits the voice. Renders
// its ruled empty-state line rather than vanishing: a placeholder row keeps
// the rhythm and reads as season-aware, not abandoned.
//
// entry.id = filename slug (url), entry.data.slug = display title
// (see content.config.ts header).
import { getCollection } from 'astro:content';
import { shortDate } from '@/lib/formatDate';

const entries = (await getCollection('wax_entries'))
  .sort((a, b) => +b.data.date - +a.data.date || a.id.localeCompare(b.id))
  .slice(0, 3);
---
<section class="bg-paper text-ink border-t border-ink/15">
  <div class="mx-auto max-w-7xl px-6 md:px-10">
    <span class="inline-block -translate-y-1/2 pr-4 text-sm tracking-wide bg-paper text-mint-deep">Wax Room</span>
    <div class="pt-2 pb-16 md:pb-20">
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-display text-3xl md:text-4xl text-navy leading-[1.05]">From the Wax Room</h2>
        <a href="/wax-room" class="shrink-0 text-mint-deep text-sm hover:text-navy">All entries</a>
      </div>
      {entries.length === 0 ? (
        <p class="py-5 border-y border-ink/10 text-slate">
          No entries yet. Come back after the first snow.
        </p>
      ) : (
        <ul class="border-y border-ink/10 divide-y divide-ink/10">
          {entries.map((e) => (
            <li>
              <a
                href={'/wax-room/' + e.id}
                class="group grid items-baseline gap-x-6 gap-y-1 py-4 md:grid-cols-[8.5rem_1fr_auto]"
              >
                <span class="text-xs text-mint-deep tabular-nums">
                  {shortDate(e.data.date)}{e.data.author_name ? ` · ${e.data.author_name}` : ''}
                </span>
                <span class="font-display text-lg text-navy leading-tight transition-colors duration-150 group-hover:text-mint-deep">
                  {e.data.slug}
                  {e.data.lede && (
                    <span class="ml-3 font-sans text-sm font-normal text-slate">{e.data.lede}</span>
                  )}
                </span>
                {e.data.conditions_snapshot?.temp_f != null && (
                  <span class="text-xs text-slate tabular-nums">
                    {e.data.conditions_snapshot.temp_f}°F
                    {e.data.conditions_snapshot.location ? ` · ${e.data.conditions_snapshot.location}` : ''}
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</section>
