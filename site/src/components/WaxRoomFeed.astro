---
// WaxRoomFeed: home-page strip of the three newest Wax Room entries.
// Renders nothing when the collection is empty (pre-season state).
//
// entry.id = filename slug (url), entry.data.slug = display title
// (see content.config.ts header).
//
// CONTRAST: the "All entries" link uses text-mint/80 on bg-navy; mint-deep
// on navy fails AA (same finding as the SectionBand review).
import { getCollection } from 'astro:content';
import { shortDate } from '@/lib/formatDate';

const entries = (await getCollection('wax_entries'))
  .sort((a, b) => +b.data.date - +a.data.date || a.id.localeCompare(b.id))
  .slice(0, 3);
---
{entries.length > 0 && (
  <section class="bg-navy py-20">
    <div class="mx-auto max-w-7xl px-6">
      <div class="flex items-end justify-between mb-8">
        <div>
          <div class="text-sm font-semibold tracking-wider mb-3 text-mint">03 · Wax Room</div>
          <h2 class="font-display text-3xl md:text-4xl text-paper leading-[1.05]">From the Wax Room</h2>
        </div>
        <a href="/wax-room" class="shrink-0 text-mint/80 text-sm hover:text-mint">All entries</a>
      </div>
      <div class="grid md:grid-cols-3 gap-px bg-mint/10">
        {entries.map((e) => (
          <a href={'/wax-room/' + e.id} class="bg-navy p-6 hover:bg-navy-deep transition-colors">
            <div class="text-xs text-coral tracking-wider uppercase">
              {shortDate(e.data.date)}
            </div>
            <h3 class="font-display text-xl text-mint mt-2 leading-tight">{e.data.slug}</h3>
            {e.data.lede && <p class="mt-3 text-sm text-paper/80 line-clamp-3">{e.data.lede}</p>}
          </a>
        ))}
      </div>
    </div>
  </section>
)}
