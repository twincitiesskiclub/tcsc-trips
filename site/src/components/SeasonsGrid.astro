---
// SeasonsGrid: two-up grid of practice seasons (fees, dates, what's included).
// Renders nothing at all when no seasons exist (content lands in a later phase).
// entry.id is the file-name slug; entry.data.slug is the DISPLAY NAME
// (see content.config.ts header).
import { getCollection } from 'astro:content';

interface Props {
  variant?: 'navy' | 'paper';
}
const { variant = 'navy' } = Astro.props;

const seasons = await getCollection('practice_seasons');
seasons.sort((a, b) => a.id.localeCompare(b.id));

const dollar = (cents: number) =>
  (cents / 100).toLocaleString('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 0,
  });

// Hairline divider: the wrapper carries the tinted divider color as its
// background and the opaque season cells sit on top, so the 1px grid gap
// reads as a single hairline between cells (no doubled per-cell borders,
// no extra perimeter).
const hairline = variant === 'navy' ? 'bg-mint/20' : 'bg-ink/15';
const surface = variant === 'navy' ? 'bg-navy text-paper' : 'bg-paper text-ink';
const accent = variant === 'navy' ? 'text-mint' : 'text-mint-deep';
---
{seasons.length > 0 && (
  <div class:list={['grid md:grid-cols-2 gap-px', hairline]}>
    {seasons.map((s) => (
      <div class:list={['p-8 md:p-10', surface]}>
        <p class:list={['text-sm uppercase tracking-widest', accent]}>{s.data.date_range}</p>
        <h3 class="mt-3 font-display text-2xl md:text-3xl">{s.data.slug}</h3>
        <p class:list={['mt-2 text-lg font-semibold', accent]}>{dollar(s.data.fee_cents)}</p>
        <p class="mt-4 max-w-prose">{s.data.summary}</p>
        {s.data.what_included.length > 0 && (
          <ul class="mt-6 space-y-1 text-sm">
            {s.data.what_included.map((item) => <li>· {item}</li>)}
          </ul>
        )}
      </div>
    ))}
  </div>
)}
