---
// CoachEntry: asymmetric editorial split (NOT a card, per the design
// system). Photo holds a constrained 5-column 4:5 portrait; name + bio take
// the wide column; entries alternate sides via `flip`. Bio body comes
// through the slot (render(entry) Content at the call site).
//
// WHY CONSTRAINED, NOT FULL-BLEED: coach source photos are modest quality
// (KJ's is visibly soft at full size). A 21:9 full-bleed mount magnified
// that softness across 1440+ px; at ~460px CSS (920 device px at 2x) the
// same sources read sharp. If crisp 3000px+ portraits ever arrive, the
// full-bleed treatment can come back.
//
// CROP STRATEGY: sources are square-ish, the slot is 4:5. The crop happens
// server-side (width + 4:5-derived height makes sharp emit true 4:5
// renditions) and position="attention" uses sharp's saliency crop, which
// chases faces instead of the geometric center. `object_position` remains
// as a CSS fallback for rounding slack, biased ~30% from top where heads
// live.
import { Image } from 'astro:assets';
import { CARD } from '@/components/imageWidths';

interface Props {
  name: string;
  role: string;
  photo: ImageMetadata;
  photoAlt: string;
  credentials?: string[];
  /** Anchor id for deep links (scroll-margin handled here). */
  anchor?: string;
  /** CSS object-position fallback for the residual in-browser crop. */
  object_position?: string;
  /**
   * 'eager' for the first (above-the-fold) entry only: its photo is the
   * page's LCP element, and lazy-loading it failed Lighthouse's
   * lcp-lazy-loaded audit. Entries below the fold stay lazy.
   */
  loading?: 'eager' | 'lazy';
}
const {
  name,
  role,
  photo,
  photoAlt,
  credentials = [],
  anchor,
  object_position = 'center 30%',
  loading = 'lazy',
} = Astro.props;

const width = Math.min(1200, photo.width);
const height = Math.round((width * 5) / 4);
---
<article id={anchor} class="border-b border-ink/10 last:border-b-0 scroll-mt-24">
  {/* All photos sit left: a steady column instead of an alternator
      performing fake variety. */}
  <div class="mx-auto max-w-6xl px-6 py-12 md:py-16 grid gap-8 md:gap-14 md:grid-cols-12 items-start">
    <div class="md:col-span-5">
      <div class="relative aspect-[4/5] overflow-hidden">
        <Image
          src={photo}
          alt={photoAlt}
          widths={CARD}
          width={width}
          height={height}
          fit="cover"
          position="attention"
          sizes="(min-width: 768px) 40vw, 100vw"
          class="absolute inset-0 w-full h-full object-cover"
          style={`object-position: ${object_position}`}
          loading={loading}
          fetchpriority={loading === 'eager' ? 'high' : 'auto'}
          decoding="async"
        />
      </div>
    </div>
    <div class="md:col-span-7">
      {/* Plain sentence-case role: uppercase tracked labels repeated four
          times down the page read as scaffolding, not information. */}
      <h2 class="font-display font-semibold text-3xl md:text-5xl text-navy leading-[1.0]">{name}</h2>
      <p class="mt-2 text-mint-deep font-semibold">{role}</p>
      <div class="mt-6 prose prose-lg max-w-prose text-ink">
        <slot />
      </div>
      {credentials.length > 0 && (
        <ul class="mt-6 text-sm text-slate space-y-1">
          {credentials.map((c) => (
            <li class="before:content-['·'] before:mr-2">{c}</li>
          ))}
        </ul>
      )}
    </div>
  </div>
</article>
