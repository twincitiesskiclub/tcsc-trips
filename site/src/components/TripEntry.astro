---
// TripEntry: full trip detail body on paper. `what_to_expect` markdoc body
// comes through the slot (render(entry) Content at the call site). Props are
// snake_case to mirror the trips collection fields 1:1.
//
// MOUNTING CONTRACT: sizes="100vw" assumes the article mounts unconstrained
// (true full-bleed); a width-capped wrapper would over-fetch. TripEntry owns
// the page <h1>: mount exactly one per page, with no other h1 on it.
//
// The hero is the LCP element on a trip detail page, hence eager +
// fetchpriority=high by default (override `loading` for any secondary
// mount).
import { Image } from 'astro:assets';
import { FULL_BLEED } from '@/components/imageWidths';

interface Props {
  name: string;
  location: string;
  dates: string;
  cost_summary: string;
  signup_deadline?: string;
  capacity?: string;
  signup_url?: string;
  hero_photo?: ImageMetadata;
  /** Maps from the optional `hero_photo_alt` content field. */
  hero_photo_alt?: string;
  loading?: 'eager' | 'lazy';
}
const {
  name,
  location,
  dates,
  cost_summary,
  signup_deadline,
  capacity,
  signup_url,
  hero_photo,
  hero_photo_alt = '',
  loading = 'eager',
} = Astro.props;
---
<article class="bg-paper text-ink">
  {hero_photo && (
    <div class="relative aspect-[21/9] overflow-hidden">
      <Image
        src={hero_photo}
        alt={hero_photo_alt}
        widths={FULL_BLEED}
        width={Math.min(1920, hero_photo.width)}
        sizes="100vw"
        class="absolute inset-0 w-full h-full object-cover"
        loading={loading}
        fetchpriority={loading === 'eager' ? 'high' : 'auto'}
        decoding="async"
      />
    </div>
  )}
  <div class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="font-display text-4xl md:text-6xl text-navy leading-[1.0]">{name}</h1>
    <p class="mt-3 text-mint-deep text-sm tracking-wider uppercase font-semibold">
      {location} · {dates}
    </p>
    <div class="mt-6 prose prose-lg max-w-prose text-ink">
      <slot />
    </div>
    <dl class="mt-10 grid gap-6 sm:grid-cols-3 text-sm">
      <div>
        <dt class="text-slate uppercase tracking-wider">Cost</dt>
        <dd class="mt-1 font-semibold text-ink">{cost_summary}</dd>
      </div>
      {signup_deadline && (
        <div>
          <dt class="text-slate uppercase tracking-wider">Sign up by</dt>
          <dd class="mt-1 font-semibold text-ink">{signup_deadline}</dd>
        </div>
      )}
      {capacity && (
        <div>
          <dt class="text-slate uppercase tracking-wider">Capacity</dt>
          <dd class="mt-1 font-semibold text-ink">{capacity}</dd>
        </div>
      )}
    </dl>
    {signup_url && (
      <a
        href={signup_url}
        class="mt-10 inline-block rounded-md bg-navy px-6 py-3 font-semibold text-mint"
      >
        Sign up &rarr;
      </a>
    )}
  </div>
</article>
