---
// TripsTable: typeset list of upcoming trips, not a data grid: a header
// row over the typical trip count (1-4 rows) read anemic, so each trip is
// a full-row link (dates / name / location). entry.id is the file-name
// slug (URL identity, /trips/<id>); entry.data.slug is the DISPLAY NAME
// (see content.config.ts header). With no trips it renders a friendly
// empty state instead of a blank list.
import { getCollection } from 'astro:content';

const trips = await getCollection('trips');
trips.sort((a, b) => a.data.order - b.data.order || a.data.dates.localeCompare(b.data.dates));
---
{trips.length === 0 ? (
  <p class="text-slate">
    No trips currently scheduled. New trips are announced here each fall;{' '}
    <a href="/contact" class="text-mint-deep underline">get in touch</a>{' '}
    if you have questions in the meantime.
  </p>
) : (
  <ul class="border-y border-ink/10 divide-y divide-ink/10">
    {trips.map((t) => (
      <li>
        <a
          href={'/trips/' + t.id}
          class="group grid items-baseline gap-x-6 gap-y-1 py-5 md:grid-cols-[7rem_1fr_auto]"
        >
          <span class="text-sm text-slate tabular-nums">{t.data.dates}</span>
          <span class="font-display text-lg md:text-xl font-semibold text-navy transition-colors duration-150 group-hover:text-mint-deep">
            {t.data.slug}
          </span>
          <span class="text-sm text-slate">{t.data.location}</span>
        </a>
      </li>
    ))}
  </ul>
)}
