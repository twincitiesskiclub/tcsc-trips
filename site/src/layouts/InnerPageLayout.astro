---
// InnerPageLayout: shared shell for every non-home page. Composes
// BaseLayout (variant inner, title/description/ogImage passthrough) +
// Nav + MobileNavPanel + compact LiveConditions (under the nav) +
// optional HeroInner + <main class="bg-paper"> slot + Footer.
//
// Pass `headline` (plus optional `subhead`) to get the standard HeroInner;
// omit it on pages whose main content owns the <h1> (WaxEntry detail pages
// mount exactly one h1 themselves).
//
// The default slot mounts UNCONSTRAINED inside <main>: full-bleed
// components whose comments declare a sizes="100vw" mounting contract
// (CoachEntry) and full-bleed bands (PhotoMosaic, SectionBand) go straight
// in; text content brings its own max-w-* wrapper.
//
// LiveConditions: exactly one mount per page (the client announcer assumes
// this), always the compact variant here; the prominent variant is the
// home page's alone.
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import MobileNavPanel from '@/components/MobileNavPanel.astro';
import CtaForState from '@/components/CtaForState.astro';
import HeroInner from '@/components/HeroInner.astro';
import LiveConditions from '@/components/LiveConditions.astro';
import Footer from '@/components/Footer.astro';
import { getRegistrationCta } from '@/components/registrationCta';
import type { Fact } from '@/components/heroFacts';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  headline?: string;
  subhead?: string;
  /** Static org facts for the masthead's narrow column (HeroInner). */
  facts?: Fact[];
  /** Optional full-bleed photo band under the masthead (HeroInner). */
  photo?: ImageMetadata;
  photoAlt?: string;
  photoPosition?: string;
}
const { title, description, ogImage, headline, subhead, facts, photo, photoAlt, photoPosition } = Astro.props;
const cta = await getRegistrationCta();
---
<BaseLayout title={title} variant="inner" description={description} ogImage={ogImage}>
  <Nav />
  <MobileNavPanel>
    <CtaForState slot="cta" {...cta} />
  </MobileNavPanel>
  {/* The club's pulse sits under the nav on every page, not above the
      footer: a snow club leads with the snow. */}
  <LiveConditions variant="compact" />
  {headline && (
    <HeroInner
      headline={headline}
      subhead={subhead}
      facts={facts}
      photo={photo}
      photoAlt={photoAlt}
      photoPosition={photoPosition}
    />
  )}
  <main id="main" class="bg-paper flex-1">
    <slot />
  </main>
  <Footer />
</BaseLayout>
